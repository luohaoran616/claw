{
  "name": "@claw/control-plane",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "control-plane-http": "dist/cli-http.js",
    "control-plane-mcp": "dist/cli-mcp.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start:http": "node dist/src/cli-http.js",
    "start:mcp": "node dist/src/cli-mcp.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "migrate": "tsx src/db/migrate-cli.ts",
    "smoke:postgres": "tsx scripts/live-postgres-smoke.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "fastify": "^5.6.1",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "ulid": "^3.0.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/pg": "^8.15.5",
    "pg-mem": "^3.0.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
